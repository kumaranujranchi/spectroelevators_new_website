---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Spectro Elevator – Best Elevator & Lift Company in Patna" description="Spectro Elevator provides elevator installation, maintenance, repair, and modernization services in Patna & Bihar for residential and commercial buildings." activePage="home">
  <!-- Hero Section -->
  <section id="hero-section" class="relative min-h-screen flex items-center bg-primary overflow-hidden text-white pt-24">
    <!-- Hero Image/Video Background Overlay -->
    <div class="absolute inset-0 z-0">
      <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-65 object-center">
        <source src="assets/video/lift.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/30 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-primary/80 via-primary/20 to-transparent"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-8 space-y-8" data-aos="fade-right" data-aos-duration="1000">
        <!-- Safety Stripe Pill -->
        <div class="inline-flex items-center gap-2 bg-yellow-400/10 border border-yellow-400/30 text-accent px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider">
          <span class="w-2 h-2 rounded-full bg-accent animate-ping"></span>
          Bihar's Most Trusted Elevator Brand
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-none font-heading">
          Trusted Elevator Solutions for <span class="text-accent">Residential</span> & Commercial Buildings
        </h1>
        
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl leading-relaxed">
          Spectro Elevators delivers state-of-the-art vertical mobility engineering. We build passenger, freight, and residential home lifts designed with premium European safety components and ISO certification.
        </p>

        <div class="flex flex-wrap gap-4 pt-4">
          <a href="contact.html" class="btn-quote-hero group bg-accent text-primary font-bold px-8 py-4 rounded-lg flex items-center gap-2 shadow-xl shadow-accent/20">
            <span>Get Free Quote</span>
            <i data-lucide="file-text" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"></i>
          </a>
          <a href="tel:+919608461829" class="btn-call-hero group border-2 border-white/20 text-white font-bold px-8 py-4 rounded-lg flex items-center gap-2">
            <i data-lucide="phone-call" class="w-5 h-5 transition-transform duration-300 group-hover:rotate-12"></i>
            <span>Call Now</span>
          </a>
          <a href="https://wa.me/919608461829?text=Hello%20Spectro%20Elevators%2C%20I%20am%20interested%20in%20installing%20a%20new%20lift." target="_blank" class="btn-whatsapp-hero group bg-[#25D366] text-white font-bold px-8 py-4 rounded-lg flex items-center gap-2 shadow-lg shadow-green-500/10">
            <i data-lucide="message-square" class="w-5 h-5 transition-transform duration-300 group-hover:scale-110"></i>
            <span>WhatsApp Us</span>
          </a>
        </div>
      </div>

      <!-- Quick Contact Card -->
      <div class="lg:col-span-4" data-aos="fade-left" data-aos-duration="1000">
        <div class="bg-white/5 border border-white/10 backdrop-blur-md rounded-2xl p-6 sm:p-8 shadow-2xl relative overflow-hidden">
          <div class="absolute -top-12 -right-12 w-24 h-24 bg-accent/10 rounded-full blur-xl"></div>
          
          <h3 class="text-xl font-bold font-heading mb-4 text-white flex items-center gap-2">
            <i data-lucide="mail-question" class="text-accent"></i>
            Quick Callback
          </h3>
          <p class="text-sm text-slate-300 mb-6">Leave your details and our technical expert will call you back within 15 minutes.</p>
          
          <form class="inquiry-form space-y-4" data-source="Hero Form" name="inquiry-leads" data-netlify="true">
            <input type="hidden" name="lift_type" value="Quick Callback">
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="hero-name">Full Name</label>
              <input id="hero-name" type="text" name="name" required placeholder="e.g. Anuj Kumar" class="w-full bg-primary/40 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="hero-phone">Phone Number</label>
              <input id="hero-phone" type="tel" name="phone" required placeholder="e.g. 98765 XXXXX" class="w-full bg-primary/40 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-accent text-sm">
            </div>
            <button type="submit" class="w-full bg-accent hover:bg-accentHover text-primary font-bold py-3 rounded-lg transition-custom text-sm shadow-md mt-2">
              Request Call Back
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logos Section (Infinite Smooth Marquee) -->
  <section class="py-24 bg-bgTint border-b border-slate-200 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4" data-aos="fade-up">
        <div class="flex justify-center">
          <span class="inline-flex items-center gap-1.5 bg-primary/5 border border-primary/10 text-primary font-bold px-3 py-1 rounded-full text-xs uppercase tracking-wider">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            World-Class Standards
          </span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-primary font-heading">
          Our Technology & Component Partners
        </h2>
        <p class="text-slate-600 text-sm max-w-2xl mx-auto leading-relaxed">
          We collaborate with world-leading European and global engineering manufacturers to ensure maximum safety, smooth vertical mobility, and long-lasting durability for every lift installation.
        </p>
      </div>
      
      <!-- Infinite Logo Carousel -->
      <div class="logo-marquee-wrapper" data-aos="fade-up" data-aos-delay="100">
        <div class="logo-carousel-track">
          <!-- First Set of 11 Logos -->
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/1.png" alt="Usha Martin Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/2.png" alt="ADCO Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/3.png" alt="Montanari Lifts Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/4.png" alt="Sharp Engineers Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/5.png" alt="Arkel Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/6.png" alt="Monarch Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/7.png" alt="Fermator Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/8.png" alt="Monteferro Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/9.png" alt="Bharat Bijlee Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/10.png" alt="Philbrick Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/11.png" alt="Moris Logo">
          </div>
          
          <!-- Second Set of 11 Logos (Duplicated for Seamless Loop) -->
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/1.png" alt="Usha Martin Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/2.png" alt="ADCO Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/3.png" alt="Montanari Lifts Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/4.png" alt="Sharp Engineers Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/5.png" alt="Arkel Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/6.png" alt="Monarch Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/7.png" alt="Fermator Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/8.png" alt="Monteferro Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/9.png" alt="Bharat Bijlee Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/10.png" alt="Philbrick Logo">
          </div>
          <div class="partner-logo-card">
            <img src="assets/images/partner-logo/11.png" alt="Moris Logo">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Introduction Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-16 items-center">
        <!-- Visuals Grid -->
        <div class="lg:col-span-6 relative" data-aos="fade-right">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <img src="https://images.unsplash.com/photo-1517524206127-48bbd363f3d7?auto=format&fit=crop&w=400&q=80" alt="Mechanical elevator parts calibration" class="rounded-xl shadow-lg w-full h-48 object-cover">
              <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=400&q=80" alt="Modern glass commercial building" class="rounded-xl shadow-lg w-full h-64 object-cover">
            </div>
            <div class="space-y-4 pt-8">
              <img src="https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&w=400&q=80" alt="Technical maintenance team" class="rounded-xl shadow-lg w-full h-64 object-cover">
              <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=400&q=80" alt="ISO quality check" class="rounded-xl shadow-lg w-full h-48 object-cover">
            </div>
          </div>
          <!-- Years of Experience badge -->
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-primary text-white p-6 rounded-2xl border-4 border-white shadow-2xl text-center max-w-[160px] animate-float">
            <span class="block text-4xl font-extrabold text-accent font-heading">15+</span>
            <span class="block text-xs uppercase font-bold tracking-wider mt-1 text-slate-300">Years of Engineering Excellence</span>
          </div>
        </div>

        <!-- Copy -->
        <div class="lg:col-span-6 space-y-8" data-aos="fade-left">
          <div class="space-y-2">
            <span class="text-sm font-bold text-accent uppercase tracking-wider bg-primary px-3 py-1 rounded">Who We Are</span>
            <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-primary font-heading">Setting High Standards as a Top Elevator Company in Patna</h2>
          </div>
          
          <p class="text-slate-600 leading-relaxed">
            Founded with a vision to build safe, durable, and highly efficient lifts, Spectro Elevators has grown into Bihar's leading vertical transportation specialist and the most reliable Lift Company in Patna. From elegant home lifts to complex high-capacity freight elevators, we design, manufacture, install, and support them all under strict ISO standards.
          </p>

          <div class="grid sm:grid-cols-2 gap-6">
            <div class="flex gap-4 items-start">
              <div class="bg-slate-100 p-2.5 rounded text-primary">
                <i data-lucide="shield-check" class="w-6 h-6 text-emerald-600"></i>
              </div>
              <div>
                <h4 class="font-bold text-primary">ISO Quality Standards</h4>
                <p class="text-xs text-slate-500 mt-1">Strict adhering to safety rules & CE certification guidelines.</p>
              </div>
            </div>
            
            <div class="flex gap-4 items-start">
              <div class="bg-slate-100 p-2.5 rounded text-primary">
                <i data-lucide="map-pin" class="w-6 h-6 text-accent"></i>
              </div>
              <div>
                <h4 class="font-bold text-primary">Bihar Coverage</h4>
                <p class="text-xs text-slate-500 mt-1">Service locations in Patna, Muzaffarpur, Gaya, Bhagalpur, and Purnia.</p>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="bg-slate-100 p-2.5 rounded text-primary">
                <i data-lucide="cpu" class="w-6 h-6 text-indigo-600"></i>
              </div>
              <div>
                <h4 class="font-bold text-primary">Latest MRL Tech</h4>
                <p class="text-xs text-slate-500 mt-1">Space-saving Machine Room-less solutions for villas & buildings.</p>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="bg-slate-100 p-2.5 rounded text-primary">
                <i data-lucide="clock" class="w-6 h-6 text-rose-500"></i>
              </div>
              <div>
                <h4 class="font-bold text-primary">24x7 Customer Support</h4>
                <p class="text-xs text-slate-500 mt-1">Active emergency rescue services available 365 days a year.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lift Categories Section -->
  <section class="py-24 bg-bgTint border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4" data-aos="fade-up">
        <span class="text-sm font-bold text-accent uppercase tracking-wider bg-primary px-3 py-1 rounded">Our Products</span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-primary font-heading">Elevator Categories Built for Bihar's Demands</h2>
        <p class="text-slate-600">Explore our range of elevators. We custom-build every project with state-of-the-art tech and safety components.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Passenger Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="100">
          <div class="zoom-container h-48 bg-slate-200 relative">
            <img src="assets/images/lifts/passanger lift.png" alt="Modern passenger elevator cabin interior" class="w-full h-full object-cover">
            <div class="absolute top-4 left-4 bg-primary text-white text-xs font-bold px-2.5 py-1 rounded">Popular</div>
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Passenger Lift Installation</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Smooth, fast, and highly reliable elevators for high-rise residential apartments and busy office complexes.</p>
            <a href="products.html#passenger" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Hospital Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="200">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/Hospital Lift.png" alt="Hospital elevator wide entry door" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Hospital Lift</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Wide cabin structure optimized to accommodate stretchers, beds, medical staff, and sensitive equipment safely.</p>
            <a href="products.html#hospital" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Goods/Freight Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="300">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/goods lift.png" alt="Heavy freight cargo elevator loading" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Goods/Freight Lift</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Heavy-duty steel construction built to transport materials in factories, warehouses, and shopping malls.</p>
            <a href="products.html#goods" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- MRL Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="400">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/mrl lift.png" alt="Machine roomless elevator controller" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">MRL Lift</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Machine Room-Less (MRL) gearless lifts that save valuable space, operate silently, and reduce energy consumption by 40%.</p>
            <a href="products.html#mrl" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Home Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="100">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/home lift.png" alt="Luxury home elevator glass cabin" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Home Lift Installation</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Compact, single-phase lifts for duplex villas and bungalows. Minimal civil work required, runs on standard electricity.</p>
            <a href="products.html#home" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Capsule Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="200">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/capsul lift.png" alt="Scenic glass capsule elevator" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Capsule Lift</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Scenic glass elevators that elevate the aesthetic appeal of commercial malls, hotels, and luxury complexes.</p>
            <a href="products.html#capsule" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Hydraulic Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="300">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/Hydraulic Lift.png" alt="Hydraulic piston mechanisms" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Hydraulic Lift</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Excellent load-carrying capacity with smooth starts and stops. Best suited for low-rise commercial structures.</p>
            <a href="products.html#hydraulic" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Automobile Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="400">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/automobile lift.png" alt="Car elevator lift mechanism" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Automobile Lift</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Super-reinforced car elevators built for multi-level parking showrooms and luxury auto garages.</p>
            <a href="products.html#automobile" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Service Lift / Dumbwaiter -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="100">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/lifts/dumbwaiter service lift .png" alt="Stainless steel kitchen dumbwaiter lift" class="w-full h-full object-cover">
          </div>
          <div class="p-6 space-y-4">
            <h3 class="font-bold text-xl text-primary font-heading">Service Lift / Dumbwaiter</h3>
            <p class="text-sm text-slate-500 line-clamp-3">Compact lift for transporting food, laundry, documents, and small items between floors. Ideal for hotels, clinics, and residences.</p>
            <a href="products.html#service" class="w-full block text-center bg-slate-100 hover:bg-accent hover:text-primary text-primary font-bold py-2.5 rounded transition-custom text-sm">
              View Details
            </a>
          </div>
        </div>

        <!-- Outdoor Lift -->
        <div class="bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden group hover:shadow-2xl transition-custom transform hover:-translate-y-1" data-aos="fade-up" data-aos-delay="200">
          <div class="zoom-container h-48 bg-slate-200">
            <img src="assets/images/outdoor_lift.png" alt="Panoramic outdoor glass elevator on facade" class="w-full h-full object-cover">
          </div>
