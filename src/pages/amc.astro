---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Elevator AMC Services & Maintenance Plans | Spectro Elevators" description="Maintain your elevator system's safety and uptime with our Elevator Maintenance Services. Compare our Semi-Comprehensive and Comprehensive AMC plans with 24x7 emergency response in Bihar." activePage="amc">
  <!-- Inner Page Hero -->
  <section class="relative bg-primary py-24 text-white overflow-hidden pt-36">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=1920&q=80" alt="Technician checking rope tension" class="w-full h-full object-cover opacity-20">
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/95 to-primary"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4" data-aos="fade-up">
      <h1 class="text-4xl sm:text-5xl font-extrabold font-heading">Elevator AMC Services</h1>
      <div class="w-20 h-1 bg-accent mx-auto"></div>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">Keep your elevator running smoothly and safely. Discover our tailored Elevator AMC Services, monthly servicing structures, and preventative audit checklists.</p>
    </div>
  </section>

  <!-- AMC Plan Compare Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Copy -->
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4" data-aos="fade-up">
        <span class="text-sm font-bold text-accent uppercase tracking-wider bg-primary px-3 py-1 rounded">AMC Schemes</span>
        <h2 class="text-3xl font-bold tracking-tight text-primary font-heading">Select the Maintenance Plan for Your Building</h2>
        <p class="text-slate-600">We offer two tiers of contract coverage to suit different budgets and building requirements.</p>
      </div>

      <!-- Compare Cards -->
      <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
        
        <!-- Scheme 1 -->
        <div class="bg-bgTint border border-slate-200 rounded-2xl p-8 sm:p-10 shadow-sm space-y-8 flex flex-col justify-between" data-aos="fade-right">
          <div class="space-y-6">
            <div class="space-y-2">
              <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Standard Protection</span>
              <h3 class="text-3xl font-extrabold text-primary font-heading">Semi-Comprehensive AMC</h3>
              <p class="text-sm text-slate-500">Perfect for residential buildings with low traffic and tight maintenance budgets.</p>
            </div>
            
            <div class="w-full h-[1px] bg-slate-200"></div>

            <ul class="space-y-3.5 text-sm text-slate-700">
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>12 Scheduled Visits:</strong> Monthly structural and mechanical audits.</span>
              </li>
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>24x7 Emergency Calls:</strong> Rapid breakdown technician dispatch.</span>
              </li>
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>Cleaning & Lubes:</strong> Oiling ropes, cleaning the pit, greasing rails.</span>
              </li>
              <li class="flex items-start gap-3 text-slate-400">
                <i data-lucide="x" class="w-5 h-5 text-rose-500 shrink-0 mt-0.5"></i>
                <span>Spare parts, control boards, and cables are billed extra.</span>
              </li>
            </ul>
          </div>

          <a href="contact.html?type=Semi-Comprehensive%20AMC" class="w-full block text-center bg-primary hover:bg-slate-800 text-white font-bold py-3.5 rounded-lg transition-custom text-sm shadow-md">
            Request Semi-Comprehensive Quote
          </a>
        </div>

        <!-- Scheme 2 -->
        <div class="bg-primary text-white border-2 border-accent rounded-2xl p-8 sm:p-10 shadow-xl space-y-8 flex flex-col justify-between relative overflow-hidden" data-aos="fade-left">
          <div class="absolute inset-0 safety-stripes opacity-[0.03] -skew-y-6"></div>
          <div class="relative z-10 space-y-6">
            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-xs font-bold text-accent uppercase tracking-wider">Complete Protection</span>
                <span class="bg-accent text-primary text-[10px] font-extrabold uppercase px-2 py-0.5 rounded">Highly Recommended</span>
              </div>
              <h3 class="text-3xl font-extrabold text-white font-heading">Comprehensive AMC</h3>
              <p class="text-sm text-slate-300">Best for commercial plazas, hospitals, and busy residential complexes.</p>
            </div>
            
            <div class="w-full h-[1px] bg-white/10"></div>

            <ul class="space-y-3.5 text-sm text-slate-200">
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>Includes all Standard features:</strong> 12 audits plus 24x7 helplines.</span>
              </li>
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>FREE Parts Replacement:</strong> Zero cost for control cards and displays.</span>
              </li>
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>Major Components Covered:</strong> Gearbox, motor winding, and ropes.</span>
              </li>
              <li class="flex items-start gap-3">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span><strong>No Breakdown Bill:</strong> Unlimited repairs with zero parts invoicing.</span>
              </li>
            </ul>
          </div>

          <a href="contact.html?type=Comprehensive%20AMC" class="relative z-10 w-full block text-center bg-accent hover:bg-accentHover text-primary font-bold py-3.5 rounded-lg transition-custom text-sm shadow-md">
            Request Comprehensive Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicing Process Section -->
  <section class="py-24 bg-bgTint border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4" data-aos="fade-up">
        <span class="text-sm font-bold text-accent uppercase tracking-wider bg-primary px-3 py-1 rounded">Procedure</span>
        <h2 class="text-3xl font-bold tracking-tight text-primary font-heading">Our Monthly Inspection Routine</h2>
        <p class="text-slate-600">Every scheduled AMC visit follows a strict safety procedure executed by certified elevator inspectors.</p>
      </div>

      <div class="grid sm:grid-cols-4 gap-8">
        <!-- Step 1 -->
        <div class="bg-white border border-slate-200 p-6 rounded-xl space-y-4" data-aos="fade-up" data-aos-delay="100">
          <div class="bg-slate-100 text-primary w-12 h-12 rounded-full flex items-center justify-center font-bold font-heading text-lg">01</div>
          <h4 class="font-bold text-primary text-base">Audit Log Check</h4>
          <p class="text-xs text-slate-500">We inspect the building's logbook and interview the security/staff for any reported leveling issues or noise anomalies.</p>
        </div>

        <!-- Step 2 -->
        <div class="bg-white border border-slate-200 p-6 rounded-xl space-y-4" data-aos="fade-up" data-aos-delay="200">
          <div class="bg-slate-100 text-primary w-12 h-12 rounded-full flex items-center justify-center font-bold font-heading text-lg">02</div>
          <h4 class="font-bold text-primary text-base">Machine Audit</h4>
          <p class="text-xs text-slate-500">Checking motor temperature, gear oil levels, brake pad clearances, and cable tension in the shaft or machine room.</p>
        </div>

        <!-- Step 3 -->
        <div class="bg-white border border-slate-200 p-6 rounded-xl space-y-4" data-aos="fade-up" data-aos-delay="300">
          <div class="bg-slate-100 text-primary w-12 h-12 rounded-full flex items-center justify-center font-bold font-heading text-lg">03</div>
          <h4 class="font-bold text-primary text-base">Cabin & Door Check</h4>
          <p class="text-xs text-slate-500">Testing emergency call buttons, cabin fan and lights, automatic safety sensor bar, and lock mechanisms on every landing.</p>
        </div>

        <!-- Step 4 -->
        <div class="bg-white border border-slate-200 p-6 rounded-xl space-y-4" data-aos="fade-up" data-aos-delay="400">
          <div class="bg-slate-100 text-primary w-12 h-12 rounded-full flex items-center justify-center font-bold font-heading text-lg">04</div>
          <h4 class="font-bold text-primary text-base">Safety Test Run</h4>
          <p class="text-xs text-slate-500">Testing emergency battery lowering (ARD), backup alarm trigger, and signing off the monthly service log card.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer Section -->
</Layout>
