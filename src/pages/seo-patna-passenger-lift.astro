---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Passenger Lift in Patna | Safe Automatic Elevator System Patna - Spectro" description="Looking for a reliable passenger lift in Patna? Spectro Elevators offers ISO-certified, safe gearless and traction elevators for Patna residential complexes." activePage="home">
  <!-- Hero Section -->
  <section class="relative bg-primary py-24 text-white overflow-hidden pt-36">
    <div class="absolute inset-0 z-0">
      <img src="https://imagizer.imageshack.com/img922/7523/XW6xuk.jpg" alt="Passenger elevator in Patna lobby" class="w-full h-full object-cover opacity-20">
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/95 to-primary"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6 text-center" data-aos="fade-up">
      <div class="inline-block bg-accent/10 border border-accent/25 text-accent text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
        Patna Local Division
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold font-heading leading-tight">
        Passenger Lift in Patna
      </h1>
      <div class="w-20 h-1 bg-accent mx-auto"></div>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">
        State-of-the-art automatic door elevators engineered for apartments, offices, and complexes in Patna. Full ISO certification with 24x7 local maintenance support.
      </p>
      <div class="pt-4 flex justify-center gap-4">
        <a href="#quote-form" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
          Request Site Audit in Patna
        </a>
        <a href="tel:+919608461829" class="border border-white/20 hover:border-accent hover:text-accent font-bold px-6 py-3 rounded-lg transition-custom text-sm">
          Call Local Office
        </a>
      </div>
    </div>
  </section>

  <!-- Patna Local Highlights -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-16 items-center">
      
      <!-- Content -->
      <div class="lg:col-span-7 space-y-6" data-aos="fade-right">
        <span class="text-sm font-bold text-accent uppercase tracking-wider bg-primary px-3 py-1 rounded">Local Service</span>
        <h2 class="text-3xl font-bold tracking-tight text-primary font-heading">Patna's Leading Vertical Transit Engineering Team</h2>
        <p class="text-slate-600 leading-relaxed text-sm">
          Spectro Elevators operates a full engineering branch right in Dak Bunglow Crossing, Fraser Road. This central base allows us to deploy safety inspectors and mechanics to any locality in Patna under 1 hour in case of emergencies or repair requests.
        </p>
        <p class="text-slate-600 leading-relaxed text-sm">
          Whether you are building a new 6-story residential apartment in Kankarbagh or upgrading a commercial office elevator on Boring Road, we handle the civil diagrams, steel fabrication, and electrical testing in complete compliance with Indian Standard (IS) Lift Codes.
        </p>

        <div class="grid sm:grid-cols-2 gap-4 pt-4">
          <div class="flex items-center gap-3">
            <i data-lucide="map-pin" class="w-5 h-5 text-accent"></i>
            <span class="text-sm text-slate-700 font-semibold">Kankarbagh & Rajendra Nagar</span>
          </div>
          <div class="flex items-center gap-3">
            <i data-lucide="map-pin" class="w-5 h-5 text-accent"></i>
            <span class="text-sm text-slate-700 font-semibold">Boring Road & Patliputra Colony</span>
          </div>
          <div class="flex items-center gap-3">
            <i data-lucide="map-pin" class="w-5 h-5 text-accent"></i>
            <span class="text-sm text-slate-700 font-semibold">Bailey Road & Saguna More</span>
          </div>
          <div class="flex items-center gap-3">
            <i data-lucide="map-pin" class="w-5 h-5 text-accent"></i>
            <span class="text-sm text-slate-700 font-semibold">Ashiana Nagar & Digha</span>
          </div>
        </div>
      </div>

      <!-- Specs Card -->
      <div class="lg:col-span-5" id="quote-form" data-aos="fade-left">
        <div class="bg-bgTint border border-slate-200 p-8 rounded-2xl shadow-lg space-y-6">
          <h3 class="text-xl font-bold text-primary font-heading flex items-center gap-2">
            <i data-lucide="calculator" class="text-accent"></i>
            Patna Price Quote
          </h3>
          <form class="inquiry-form space-y-4" data-source="Patna SEO Page Form" name="inquiry-leads" data-netlify="true">
            <input type="hidden" name="lift_type" value="Passenger Lift (Patna Inquiry)">
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="patna-name">Full Name</label>
              <input id="patna-name" type="text" name="name" required placeholder="e.g. Anand Sharma" class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="patna-phone">Phone Number</label>
              <input id="patna-phone" type="tel" name="phone" required placeholder="e.g. 98765 XXXXX" class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="patna-floors">Number of Floors</label>
              <input id="patna-floors" type="number" name="floors" placeholder="e.g. G+4" class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="patna-msg">Requirements</label>
              <textarea id="patna-msg" name="message" rows="3" placeholder="Briefly specify building details..." class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm"></textarea>
            </div>
            <button type="submit" class="w-full bg-accent hover:bg-accentHover text-primary font-bold py-3 rounded-lg transition-custom text-sm shadow-md">
              Submit & Connect on WhatsApp
            </button>
          </form>
        </div>
      </div>

    </div>
  </section>

  <!-- Footer Section -->
</Layout>
