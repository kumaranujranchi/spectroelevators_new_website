---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Elevators | Spectro Elevators - Lift Specifications and Capacities" description="Detailed guide on passenger, hospital, MRL, residential home, freight, capsule, hydraulic and car elevator capacities, speeds, and safety features." activePage="products">
  <!-- Inner Page Hero -->
  <section class="relative bg-primary py-24 text-white overflow-hidden pt-36">
    <div class="absolute inset-0 z-0">
      <img src="https://imagizer.imageshack.com/img922/7523/XW6xuk.jpg" alt="Traction cables and machinery" class="w-full h-full object-cover opacity-20">
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/95 to-primary"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4" data-aos="fade-up">
      <h1 class="text-4xl sm:text-5xl font-extrabold font-heading">Elevator Types & Tech Specs</h1>
      <div class="w-20 h-1 bg-accent mx-auto"></div>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">Comprehensive guide to capacities, speeds, mechanics, and safety features for all major vertical mobility divisions.</p>
    </div>
  </section>

  <!-- Products Main List -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-32">

      <!-- 1. Passenger Lift -->
      <div id="passenger" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-5 relative">
          <img src="assets/images/lifts/passanger lift.png" alt="Luxury passenger elevator setup" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
        <div class="lg:col-span-7 space-y-6">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 01</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Passenger Elevator Systems</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Engineered with high-efficiency gearless permanent magnet motors and smart digital microprocessors, our passenger lifts provide smooth and rapid transit within multi-family apartments and premium corporate centers.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 4 to 20 Persons (300kg - 1360kg)</li>
              <li><strong>Rated Speed:</strong> 1.0 m/s to 2.0 m/s</li>
              <li><strong>Drive Technology:</strong> Geared Traction / VVVF Gearless</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> ARD (Auto Rescue Device) + Overload Sensor</li>
              <li><strong>Primary Uses:</strong> Apartments, Offices, Hotels</li>
              <li><strong>Controller:</strong> 32-bit Microprocessor Dual Loop</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Passenger%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Passenger Lift
            </a>
            <a href="projects.html" class="border border-slate-300 hover:border-primary hover:text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm text-slate-500">
              View Installations
            </a>
          </div>
        </div>
      </div>

      <!-- 2. Hospital Lift -->
      <div id="hospital" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-7 space-y-6 order-2 lg:order-1">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 02</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Hospital & Stretcher Lifts</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Designed to meet the rigorous demands of healthcare facilities, these elevators feature extra cabin depth and wide telescopic doors to comfortably slide stretchers, medical carts, patient beds, and support technicians.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 15 to 26 Persons (1025kg - 1768kg)</li>
              <li><strong>Rated Speed:</strong> 0.75 m/s to 1.5 m/s</li>
              <li><strong>Drive Technology:</strong> Gearless AC VVVF Drive</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Door Hold Button + Emergency Backup</li>
              <li><strong>Primary Uses:</strong> Hospitals, Clinics, Nursing Homes</li>
              <li><strong>Open Style:</strong> Center Opening Wide Doors</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Hospital%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Hospital Lift
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative order-1 lg:order-2">
          <img src="assets/images/lifts/Hospital Lift.png" alt="Hospital wide elevator system" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
      </div>

      <!-- 3. Goods/Freight Lift -->
      <div id="goods" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-5 relative">
          <img src="assets/images/lifts/goods lift.png" alt="Industrial goods lift" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
        <div class="lg:col-span-7 space-y-6">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 03</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Goods & Freight Elevators</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Our goods lifts are constructed with structural steel framing and checker-plate floors, engineered to bear heavy, dynamic loads. They are highly resilient and suitable for factories, warehouses, and storage hubs.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 1000 kg to 5000 kg</li>
              <li><strong>Rated Speed:</strong> 0.25 m/s to 0.75 m/s</li>
              <li><strong>Drive Technology:</strong> Heavy Geared Traction / Hydraulic</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Collapsible Gate Switch + Safety Buffer</li>
              <li><strong>Primary Uses:</strong> Factories, Storage Centers, Malls</li>
              <li><strong>Cabin Finish:</strong> Anti-slip Checker-plate Steel</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Goods%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Goods Lift
            </a>
          </div>
        </div>
      </div>

      <!-- 4. MRL Lift -->
      <div id="mrl" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-7 space-y-6 order-2 lg:order-1">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 04</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Machine Room-Less (MRL) Lifts</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            By placing the compact gearless traction machine inside the lift shaft itself, we eliminate the need for a separate rooftop machine room. This cuts structural civil work and provides high energy-efficiency.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 4 to 15 Persons (300kg - 1025kg)</li>
              <li><strong>Rated Speed:</strong> 1.0 m/s to 1.75 m/s</li>
              <li><strong>Drive Technology:</strong> Gearless Synchronous PMSM Motor</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> VVVF Smart Brake + Governor Release</li>
              <li><strong>Primary Uses:</strong> Modern Residential Flats, Offices</li>
              <li><strong>Energy Saving:</strong> Up to 40% less power consumption</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=MRL%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About MRL Lift
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative order-1 lg:order-2">
          <img src="assets/images/lifts/mrl lift.png" alt="Machine roomless elevator cabin" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
      </div>

      <!-- 5. Home Lift -->
      <div id="home" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-5 relative">
          <img src="assets/images/lifts/home lift.png" alt="Residential villa home elevator" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
        <div class="lg:col-span-7 space-y-6">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 05</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Home Lifts & Villa Elevators</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Tailor-made for luxury duplexes, bungalows, and penthouses. These lifts require no deep shaft pit (just 150mm pit or ramp) and can easily operate on single-phase domestic electrical connections.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 3 to 6 Persons (250kg - 450kg)</li>
              <li><strong>Rated Speed:</strong> 0.3 m/s to 0.5 m/s</li>
              <li><strong>Drive Technology:</strong> Hydraulic / Gearless Traction MRL</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Emergency Battery Lowering + Phone Line</li>
              <li><strong>Primary Uses:</strong> Villas, Rowhouses, Penthouse Duplexes</li>
              <li><strong>Electricity:</strong> 230V Single-Phase Standard Supply</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Home%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Home Lift
            </a>
          </div>
        </div>
      </div>

      <!-- 6. Capsule Lift -->
      <div id="capsule" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-7 space-y-6 order-2 lg:order-1">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 06</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Scenic & Capsule Lifts</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Enhance the visual aesthetics of your building with panoramic capsule lifts. Fitted with safety glass panels, custom circular shapes, and elegant lighting, these are popular choices for high-end shopping centers and hotels.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 6 to 15 Persons (408kg - 1025kg)</li>
              <li><strong>Rated Speed:</strong> 1.0 m/s to 1.5 m/s</li>
              <li><strong>Drive Technology:</strong> Gearless VVVF / Hydraulic</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Tempered Laminated Safety Glass</li>
              <li><strong>Primary Uses:</strong> Malls, Showrooms, Star Hotels</li>
              <li><strong>Cabin Options:</strong> Semi-circular, Hexagonal, Rectangular</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Capsule%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Capsule Lift
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative order-1 lg:order-2">
          <img src="assets/images/lifts/capsul lift.png" alt="Capsule scenic lift" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
      </div>

      <!-- 7. Hydraulic Lift -->
      <div id="hydraulic" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-5 relative">
          <img src="assets/images/lifts/Hydraulic Lift.png" alt="Hydraulic piston systems" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
        <div class="lg:col-span-7 space-y-6">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 07</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Hydraulic Elevator Systems</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Utilizing high-pressure hydraulic fluid pistons, these systems provide exceptional load-carrying capacities with smooth starts and landings. Best suited for low-rise commercial sites and home applications.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 3 to 12 Persons (250kg - 816kg)</li>
              <li><strong>Rated Speed:</strong> 0.3 m/s to 0.6 m/s</li>
              <li><strong>Drive Technology:</strong> Italian Hydraulic Pump Block</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Burst Valve Protection + Hand Pump Manual</li>
              <li><strong>Primary Uses:</strong> Low-Rise Buildings, Luxury Duplexes</li>
              <li><strong>Civil Advantage:</strong> No overhead machine room required</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Hydraulic%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Hydraulic Lift
            </a>
          </div>
        </div>
      </div>

      <!-- 8. Automobile Lift -->
      <div id="automobile" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-7 space-y-6 order-2 lg:order-1">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 08</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Automobile & Car Elevators</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Specially reinforced cabins built to move cars and utility vehicles between basement parking lots and multi-level showrooms. Equipped with dual control panels so drivers can operate it without stepping out.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 3000 kg to 5000 kg</li>
              <li><strong>Rated Speed:</strong> 0.25 m/s to 0.5 m/s</li>
              <li><strong>Drive Technology:</strong> Heavy Dual Hydraulic Pistons</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Photo-electric Position + Safety Buffer</li>
              <li><strong>Primary Uses:</strong> Multi-level Garages, Auto Showrooms</li>
              <li><strong>Control:</strong> Dual Operator Panels (left & right)</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Automobile%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Automobile Lift
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative order-1 lg:order-2">
          <img src="assets/images/lifts/automobile lift.png" alt="Car automobile elevator lift" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
      </div>

      <!-- 9. Service Lift / Dumbwaiter -->
      <div id="service" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-5 relative">
          <img src="assets/images/lifts/dumbwaiter service lift .png" alt="Stainless steel kitchen dumbwaiter lift" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
        <div class="lg:col-span-7 space-y-6">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 09</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Service Lifts & Dumbwaiters</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Designed for quick and hygienic transfer of food, laundry, medical supplies, and general documents across floors. Ideal for hotels, luxury residences, restaurants, and medical centers to optimize staff operations.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 50 kg to 250 kg</li>
              <li><strong>Rated Speed:</strong> 0.25 m/s to 0.4 m/s</li>
              <li><strong>Drive Technology:</strong> Compact Traction / Drum Type</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Electro-mechanical Door Interlocks</li>
              <li><strong>Primary Uses:</strong> Restaurants, Hotels, Hospitals, Pantry Rooms</li>
              <li><strong>Structure:</strong> Medical-grade Stainless Steel (SUS 304)</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Dumbwaiter%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Service Lift
            </a>
          </div>
        </div>
      </div>

      <!-- 10. Outdoor Lift -->
      <div id="outdoor" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-7 space-y-6 order-2 lg:order-1">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 10</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Outdoor & Exterior Lifts</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Custom-built to run along exterior walls, providing architectural beauty and panoramic views while saving valuable indoor space. Features full weatherproof engineering to withstand external heat, rain, and dust.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 4 to 12 Persons (300kg - 816kg)</li>
              <li><strong>Rated Speed:</strong> 0.5 m/s to 1.0 m/s</li>
              <li><strong>Drive Technology:</strong> Hydraulic / MRL Traction</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> IP54 Waterproofing + Emergency Lowering</li>
              <li><strong>Primary Uses:</strong> Commercial Facades, Scenic Villas, Glass Towers</li>
              <li><strong>Finish:</strong> Anti-corrosive Powder Coating / Stainless Steel</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Outdoor%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Outdoor Lift
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative order-1 lg:order-2">
          <img src="assets/images/outdoor_lift.png" alt="Panoramic outdoor glass elevator on facade" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
      </div>

      <!-- 11. Stair Lift / Chair Lift -->
      <div id="stair" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-5 relative">
          <img src="assets/images/stair_lift.png" alt="Sleek residential staircase chair lift" class="rounded-2xl shadow-xl w-full h-[360px] object-cover">
        </div>
        <div class="lg:col-span-7 space-y-6">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 11</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Stair Lifts & Chair Lifts</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Safe, reliable, and compact mobility solution for elderly or physically challenged family members. Installs directly onto existing staircase steps without structural changes to the home.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 120 kg to 160 kg</li>
              <li><strong>Rated Speed:</strong> 0.15 m/s</li>
              <li><strong>Drive Technology:</strong> Rack & Pinion Battery-Powered</li>
            </ul>
            <ul class="space-y-2">
              <li><strong>Key Safety:</strong> Seatbelt + Safety Obstruction Edge Sensors</li>
              <li><strong>Primary Uses:</strong> Duplex Staircases, Nursing Homes, Clinics</li>
              <li><strong>Rail Configuration:</strong> Straight or Curved Custom Tracks</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="contact.html?type=Stair%20Lift" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
              Inquire About Stair Lift
            </a>
          </div>
        </div>
      </div>

      <!-- 12. Pneumatic Vacuum Lift -->
      <div id="vacuum" class="grid lg:grid-cols-12 gap-12 items-center scroll-mt-36" data-aos="fade-up">
        <div class="lg:col-span-7 space-y-6 order-2 lg:order-1">
          <div class="flex items-center gap-2">
            <span class="bg-primary text-accent text-xs font-bold px-3 py-1 rounded">Category 12</span>
            <h2 class="text-3xl font-bold text-primary font-heading">Pneumatic Vacuum Lifts</h2>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Futuristic, air-driven circular elevators operating via vacuum pressure technology. Requires zero pit, hoistway, or machine room, making them the ultimate stylish addition for pre-existing luxury duplexes, penthouses, and homes.
          </p>
          <div class="grid sm:grid-cols-2 gap-6 bg-bgTint p-6 rounded-xl border border-slate-200 text-sm">
            <ul class="space-y-2">
              <li><strong>Capacity Range:</strong> 1 to 3 Persons (150kg - 240kg)</li>
              <li><strong>Rated Speed:</strong> 0.15 m/s to 0.2 m/s</li>
              <li><strong>Drive Technology:</strong> Pneumatic / Air Pressure Vacuum</li>
            </ul>
