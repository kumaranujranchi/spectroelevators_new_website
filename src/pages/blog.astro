---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch all posts, sort by pubDate descending
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Featured post is the newest one
const featuredPost = sortedPosts[0];

// The rest of the posts go in the grid
const gridPosts = sortedPosts.slice(1);
---

<Layout title="Blog & Insights | Spectro Elevators - Lift Installation & Safety Tips" description="Read expert guides, technical updates, safety rules, and maintenance insights about passenger, commercial, and home lifts in Patna and Bihar." activePage="blog">
  
  <!-- Inner Page Hero -->
  <section class="relative bg-primary py-24 text-white overflow-hidden pt-36">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1920&q=80" alt="Traction cables and machinery" class="w-full h-full object-cover opacity-20">
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/95 to-primary"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4" data-aos="fade-up">
      <h1 class="text-4xl sm:text-5xl font-extrabold font-heading">Elevator Blog & Insights</h1>
      <div class="w-20 h-1 bg-accent mx-auto"></div>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto font-medium">Expert guides, maintenance tips, technology updates, and safety instructions for vertical mobility in Bihar.</p>
    </div>
  </section>

  <!-- Blog Main Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Featured Post -->
      {featuredPost && (
        <div class="mb-20" data-aos="fade-up">
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-6 font-heading">Featured Post</h3>
          <div class="bg-bgTint border border-slate-200 rounded-2xl overflow-hidden shadow-lg grid lg:grid-cols-12 gap-0 group">
            <div class="lg:col-span-7 relative h-72 lg:h-auto min-h-[320px] overflow-hidden bg-slate-100">
              <img src={featuredPost.data.image} alt={featuredPost.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <span class="absolute top-4 left-4 bg-primary text-accent text-xs font-bold px-3 py-1 rounded">{featuredPost.data.category}</span>
            </div>
            <div class="lg:col-span-5 p-8 lg:p-12 flex flex-col justify-center space-y-6">
              <div class="text-xs text-slate-400 font-semibold">
                {new Date(featuredPost.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })} &bull; {featuredPost.data.readTime}
              </div>
              <h2 class="text-2xl lg:text-3xl font-bold text-primary font-heading leading-tight group-hover:text-accent transition-colors">
                <a href={`${featuredPost.slug}.html`}>{featuredPost.data.title}</a>
              </h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                {featuredPost.data.description}
              </p>
              <div class="pt-2">
                <a href={`${featuredPost.slug}.html`} class="inline-flex items-center gap-2 bg-primary hover:bg-slate-800 text-white font-bold px-6 py-3 rounded-lg text-sm transition-custom shadow-md">
                  Read Full Article <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Grid of Posts -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-8 font-heading">All Articles</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          
          {gridPosts.map(post => (
            <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 group flex flex-col justify-between" data-aos="fade-up">
              <div>
                <div class="zoom-container h-52 bg-slate-100 relative">
                  <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
                  <span class="absolute top-4 left-4 bg-primary text-accent text-xs font-bold px-3 py-1 rounded">{post.data.category}</span>
                </div>
                <div class="p-6 space-y-4">
                  <div class="text-xs text-slate-400 font-semibold">
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })} &bull; {post.data.readTime}
                  </div>
                  <h4 class="font-bold text-xl text-primary font-heading line-clamp-2 group-hover:text-accent transition-colors">
                    <a href={`${post.slug}.html`}>{post.data.title}</a>
                  </h4>
                  <p class="text-slate-600 text-sm line-clamp-3 leading-relaxed">{post.data.description}</p>
                </div>
              </div>
              <div class="p-6 pt-0">
                <a href={`${post.slug}.html`} class="text-primary hover:text-accent font-bold inline-flex items-center gap-1 text-sm border-t border-slate-100 w-full pt-4 transition-colors">
                  Read Article <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
              </div>
            </div>
          ))}

        </div>
      </div>

    </div>
  </section>

  <!-- Newsletter/CTA Section -->
  <section class="py-20 bg-primary text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,199,44,0.08),transparent_50%)]"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 space-y-8" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold font-heading">Planning to Install a New Lift?</h2>
      <p class="text-slate-300 max-w-2xl mx-auto leading-relaxed text-sm">
        Connect with our technical engineers for a free site survey, customized drawing plans, and detailed elevator quotation.
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-2">
        <a href="contact.html" class="bg-accent hover:bg-accentHover text-primary font-bold px-8 py-3.5 rounded-lg transition-custom shadow-lg shadow-accent/20">
          Request Free Site Survey
        </a>
        <a href="tel:+919608461829" class="border border-white/20 hover:border-accent hover:text-accent text-white font-bold px-8 py-3.5 rounded-lg transition-custom">
          Call Technical Dispatch
        </a>
      </div>
    </div>
  </section>

</Layout>
