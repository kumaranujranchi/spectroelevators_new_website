---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home Lift Installation Bihar | Private Villa Elevators - Spectro" description="Looking for home lift installation in Bihar? Spectro Elevators provides custom hydraulic, MRL, and glass capsule elevators for luxury duplex villas in Patna and Bihar." activePage="home">
  <!-- Hero Section -->
  <section class="relative bg-primary py-24 text-white overflow-hidden pt-36">
    <div class="absolute inset-0 z-0">
      <img src="assets/images/lifts/home lift.png" alt="Luxury duplex home lift" class="w-full h-full object-cover opacity-25">
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/95 to-primary"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6 text-center" data-aos="fade-up">
      <div class="inline-block bg-accent/10 border border-accent/25 text-accent text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
        Bihar Residential Division
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold font-heading leading-tight">
        Home Lift Installation Bihar
      </h1>
      <div class="w-20 h-1 bg-accent mx-auto"></div>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">
        Tailor-made elevators for private villas, bungalows, and duplex houses. Operate on standard domestic single-phase power, with no overhead machine room or deep pit needed.
      </p>
      <div class="pt-4 flex justify-center gap-4">
        <a href="#quote-form" class="bg-accent hover:bg-accentHover text-primary font-bold px-6 py-3 rounded-lg transition-custom text-sm shadow-md">
          Request Home Site Survey
        </a>
        <a href="https://wa.me/919608461829?text=I%20want%20to%20install%20a%20home%20lift%20in%20Bihar." target="_blank" class="bg-[#25D366] hover:bg-[#20ba5a] text-white font-bold px-6 py-3 rounded-lg transition-custom text-sm flex items-center gap-2">
          <i data-lucide="message-square" class="w-4 h-4"></i>
          <span>WhatsApp Chat</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Bihar Home Lift Features -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-16 items-center">
      
      <!-- Content -->
      <div class="lg:col-span-7 space-y-6" data-aos="fade-right">
        <span class="text-sm font-bold text-accent uppercase tracking-wider bg-primary px-3 py-1 rounded">Villa Elevator Systems</span>
        <h2 class="text-3xl font-bold tracking-tight text-primary font-heading">Compact, Pit-less, and Single-Phase Lifts for Bihar Homes</h2>
        <p class="text-slate-600 leading-relaxed text-sm">
          Residential bungalows require compact systems that do not alter the building's structural integrity. At Spectro Elevators, we import high-quality Italian hydraulic pistons and gearless MRL traction kits that fit alongside existing staircases.
        </p>
        <p class="text-slate-600 leading-relaxed text-sm">
          Our home lifts require a pit depth of only 150mm (about 6 inches) or can be accessed via a low floor ramp. They are engineered to operate on standard 220V single-phase electrical meters, consuming as much power as a standard 1.5-ton split air conditioner.
        </p>

        <div class="grid sm:grid-cols-2 gap-4 pt-4 text-slate-700 text-sm font-medium">
          <div class="flex items-center gap-3">
            <i data-lucide="check-circle" class="w-5 h-5 text-accent"></i>
            <span>No overhead machine room needed</span>
          </div>
          <div class="flex items-center gap-3">
            <i data-lucide="check-circle" class="w-5 h-5 text-accent"></i>
            <span>Pit-less or low 150mm pit designs</span>
          </div>
          <div class="flex items-center gap-3">
            <i data-lucide="check-circle" class="w-5 h-5 text-accent"></i>
            <span>Single-phase domestic electricity</span>
          </div>
          <div class="flex items-center gap-3">
            <i data-lucide="check-circle" class="w-5 h-5 text-accent"></i>
            <span>Automatic battery lowering (ARD) built-in</span>
          </div>
        </div>
      </div>

      <!-- Form Card -->
      <div class="lg:col-span-5" id="quote-form" data-aos="fade-left">
        <div class="bg-bgTint border border-slate-200 p-8 rounded-2xl shadow-lg space-y-6">
          <h3 class="text-xl font-bold text-primary font-heading flex items-center gap-2">
            <i data-lucide="home" class="text-accent"></i>
            Home Lift Quote
          </h3>
          <form class="inquiry-form space-y-4" data-source="Bihar Home SEO Page Form" name="inquiry-leads" data-netlify="true">
            <input type="hidden" name="lift_type" value="Home Lift (Bihar Inquiry)">
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="bihar-name">Full Name</label>
              <input id="bihar-name" type="text" name="name" required placeholder="e.g. Anand Sharma" class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="bihar-phone">Phone Number</label>
              <input id="bihar-phone" type="tel" name="phone" required placeholder="e.g. 98765 XXXXX" class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="bihar-location">City in Bihar</label>
              <input id="bihar-location" type="text" name="city" required placeholder="e.g. Patna, Gaya, Darbhanga" class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm">
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1" for="bihar-msg">Your Message</label>
              <textarea id="bihar-msg" name="message" rows="3" placeholder="Specify if duplex, structure status..." class="w-full bg-white border border-slate-200 rounded-lg px-4 py-2.5 text-primary focus:outline-none focus:border-accent text-sm"></textarea>
            </div>
            <button type="submit" class="w-full bg-accent hover:bg-accentHover text-primary font-bold py-3 rounded-lg transition-custom text-sm shadow-md">
              Submit & Connect on WhatsApp
            </button>
          </form>
        </div>
      </div>

    </div>
  </section>

  <!-- Footer Section -->
</Layout>
