---
interface Props {
  activePage?: string;
}
const { activePage = "home" } = Astro.props;
---

<!-- Header Section -->
<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-custom py-5 nav-glass border-b border-white/10 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
    <a href="index.html" class="flex items-center gap-3 shrink-0 group">
      <div class="bg-accent p-1 rounded text-primary transition-custom group-hover:bg-white w-10 h-10 flex items-center justify-center overflow-hidden">
        <img src="/assets/images/logo/favicon_spectro.png" alt="Spectro Elevators Logo" class="w-8 h-8 object-contain">
      </div>
      <span class="font-bold text-base sm:text-lg xl:text-xl tracking-wider font-heading">SPECTRO <span class="text-accent group-hover:text-white transition-custom">ELEVATORS</span></span>
    </a>

    <!-- Desktop Navigation Menu -->
    <nav class="hidden lg:flex items-center gap-4 xl:gap-6 font-medium text-xs xl:text-sm whitespace-nowrap">
      <a href="index.html" class={activePage === "home" ? "text-accent transition-colors" : "hover:text-accent transition-colors"}>Home</a>
      <a href="products.html" class={activePage === "products" ? "text-accent transition-colors" : "hover:text-accent transition-colors"}>Lift Types</a>
      <a href="services.html" class={activePage === "services" ? "text-accent transition-colors" : "hover:text-accent transition-colors"}>Services</a>
      <a href="amc.html" class={activePage === "amc" ? "text-accent transition-colors" : "hover:text-accent transition-colors"}>AMC Program</a>
      <a href="coverage.html" class={activePage === "coverage" ? "text-accent transition-colors" : "hover:text-accent transition-colors"}>Coverage</a>
      <a href="contact.html" class={activePage === "contact" ? "text-accent transition-colors" : "hover:text-accent transition-colors"}>Contact</a>
    </nav>

    <div class="hidden lg:flex items-center gap-3 xl:gap-4 shrink-0 whitespace-nowrap">
      <a href="tel:+919608461829" class="flex items-center gap-1.5 text-xs xl:text-sm text-slate-300 hover:text-accent transition-colors">
        <i data-lucide="phone-call" class="w-4 h-4 text-accent shrink-0"></i>
        <span>+91 98014 51329</span>
      </a>
      <a href="contact.html" class="bg-accent hover:bg-accentHover text-primary font-bold px-4 py-2 xl:px-5 xl:py-2.5 rounded transition-custom text-xs xl:text-sm shadow-lg shadow-accent/20">
        Get Quote
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden text-white hover:text-accent transition-colors focus:outline-none" aria-label="Open Navigation Menu">
      <i data-lucide="menu" class="w-7 h-7"></i>
    </button>
  </div>
</header>

<!-- Mobile Side Drawer -->
<div id="mobile-menu" class="fixed inset-0 z-50 transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden flex justify-end">
  <div class="absolute inset-0 bg-primary/70 backdrop-blur-sm" id="mobile-overlay"></div>
  <div class="relative w-80 max-w-xs h-full bg-primary border-l border-white/10 flex flex-col justify-between py-6 px-6 shadow-2xl text-white">
    <div>
      <div class="flex items-center justify-between mb-8">
        <span class="font-bold text-lg font-heading">SPECTRO <span class="text-accent">ELEVATORS</span></span>
        <button id="close-menu-btn" class="hover:text-accent transition-colors" aria-label="Close Navigation Menu">
          <i data-lucide="x" class="w-6 h-6"></i>
        </button>
      </div>
      <nav class="flex flex-col gap-5 text-lg font-medium">
        <a href="index.html" class={activePage === "home" ? "text-accent" : "hover:text-accent"}>Home</a>
        <a href="about.html" class={activePage === "about" ? "text-accent" : "hover:text-accent"}>About Us</a>
        <a href="products.html" class={activePage === "products" ? "text-accent" : "hover:text-accent"}>Lift Types</a>
        <a href="services.html" class={activePage === "services" ? "text-accent" : "hover:text-accent"}>Services</a>
        <a href="projects.html" class={activePage === "projects" ? "text-accent" : "hover:text-accent"}>Gallery</a>
        <a href="amc.html" class={activePage === "amc" ? "text-accent" : "hover:text-accent"}>AMC Program</a>
        <a href="coverage.html" class={activePage === "coverage" ? "text-accent" : "hover:text-accent"}>Coverage</a>
        <a href="contact.html" class={activePage === "contact" ? "text-accent" : "hover:text-accent"}>Contact</a>
      </nav>
    </div>
    <div class="flex flex-col gap-4">
      <a href="tel:+919608461829" class="flex items-center gap-3 bg-white/5 border border-white/10 p-3 rounded hover:bg-white/10 transition-colors">
        <i data-lucide="phone" class="w-5 h-5 text-accent"></i>
        <span class="font-medium text-sm">+91 98014 51329</span>
      </a>
      <a href="contact.html" class="bg-accent hover:bg-accentHover text-primary text-center font-bold py-3 rounded transition-custom shadow-lg">
        Get Free Quote
      </a>
    </div>
  </div>
</div>
