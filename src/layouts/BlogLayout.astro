---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    readTime: string;
    category: string;
    image: string;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;

// Format date
const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={`${frontmatter.title} | Spectro Elevators Patna`} description={frontmatter.description} activePage="blog">
  
  <!-- Blog Banner Hero Section -->
  <section class="relative bg-primary pt-36 pb-20 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-primary via-primary/95 to-slate-50"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,199,44,0.1),transparent_60%)]"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs sm:text-sm text-slate-400 mb-6" data-aos="fade-up">
        <a href="index.html" class="hover:text-accent transition-colors">Home</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a href="blog.html" class="hover:text-accent transition-colors">Blog</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-200 truncate">{frontmatter.title}</span>
      </nav>

      <!-- Post Header Info -->
      <div class="space-y-4 max-w-4xl" data-aos="fade-up" data-aos-delay="100">
        <span class="inline-flex items-center gap-1.5 bg-accent/15 text-accent border border-accent/30 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
          <i data-lucide="book-open" class="w-3.5 h-3.5"></i> {frontmatter.category}
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold font-heading leading-tight text-white">
          {frontmatter.title}
        </h1>
        <div class="flex flex-wrap items-center gap-6 text-sm text-slate-300 pt-2 font-medium">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-accent/20 border border-accent/40 flex items-center justify-center text-accent text-xs font-bold">SE</div>
            <span>By Spectro Editorial Team</span>
          </div>
          <div class="flex items-center gap-1.5">
            <i data-lucide="calendar" class="w-4 h-4 text-accent"></i>
            <span>{formattedDate}</span>
          </div>
          <div class="flex items-center gap-1.5">
            <i data-lucide="clock" class="w-4 h-4 text-accent"></i>
            <span>{frontmatter.readTime}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Article Content Section -->
  <section class="pb-24 -mt-8 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-10">
        
        <!-- Article Body Column -->
        <article class="lg:col-span-8 bg-white border border-slate-200/80 rounded-2xl p-6 sm:p-10 shadow-xl" data-aos="fade-up" data-aos-delay="200">
          <!-- Featured Image -->
          <div class="w-full rounded-xl overflow-hidden mb-10 shadow-lg border border-slate-100 bg-slate-100 max-h-[460px]">
            <img src={frontmatter.image} alt={frontmatter.title} class="w-full h-full object-cover">
          </div>

          <!-- Dynamic Markdown Content Slot -->
          <div class="prose max-w-none text-slate-600 text-base sm:text-lg leading-relaxed space-y-6 blog-content-body">
            <slot />
          </div>

          <!-- Social Share and Tags -->
          <div class="mt-12 pt-8 border-t border-slate-100 flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap gap-2">
              <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded">#SpectroElevators</span>
              <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded">#PatnaLifts</span>
              <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded">#{frontmatter.category}</span>
            </div>
            
            <div class="flex items-center gap-3">
              <span class="text-xs text-slate-400 font-bold uppercase tracking-wider">Share:</span>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=https://spectroelevators.com/${slug}.html`} target="_blank" class="w-8 h-8 rounded-full bg-slate-100 hover:bg-accent hover:text-primary transition-colors flex items-center justify-center text-slate-500" aria-label="Facebook Share">
                <i data-lucide="facebook" class="w-4 h-4"></i>
              </a>
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}&url=https://spectroelevators.com/${slug}.html`} target="_blank" class="w-8 h-8 rounded-full bg-slate-100 hover:bg-accent hover:text-primary transition-colors flex items-center justify-center text-slate-500" aria-label="Twitter Share">
                <i data-lucide="twitter" class="w-4 h-4"></i>
              </a>
            </div>
          </div>
        </article>

        <!-- Sidebar Column -->
        <Sidebar currentSlug={slug} sourceName={`Blog: ${frontmatter.title}`} />

      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* Montserrat headers for Markdown blogs */
  .blog-content-body h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #0B192C;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .blog-content-body h2::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 28px;
    background-color: #FFC72C;
    border-radius: 9999px;
    flex-shrink: 0;
  }
  .blog-content-body h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0B192C;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .blog-content-body h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0B192C;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .blog-content-body p {
    margin-bottom: 1.5rem;
  }
  .blog-content-body strong {
    color: #0B192C;
    font-weight: 700;
  }
  .blog-content-body ul {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .blog-content-body ul li {
    position: relative;
    padding-left: 1.75rem;
    font-size: 0.95rem;
    line-height: 1.625;
    color: #475569;
  }
  .blog-content-body ul li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 2px;
    color: #FFC72C;
    font-weight: 900;
    font-size: 1.1rem;
  }
  
  /* Ol list styling */
  .blog-content-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    list-style-type: decimal;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #475569;
  }

  /* Table styling */
  .blog-content-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.875rem;
    border: 1px solid #E2E8F0;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .blog-content-body thead {
    background-color: #0B192C;
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .blog-content-body th, .blog-content-body td {
    padding: 1rem;
    border-bottom: 1px solid #E2E8F0;
  }
  .blog-content-body tr:hover {
    background-color: #F8FAFC;
  }
  
  /* Horizontal line styling */
  .blog-content-body hr {
    border: 0;
    border-top: 1px solid #E2E8F0;
    margin: 2.5rem 0;
  }
</style>
